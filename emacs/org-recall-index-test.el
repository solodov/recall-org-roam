;;; org-recall-index-test.el --- Tests for org-recall-index -*- lexical-binding: t; -*-

(require 'ert)
(require 'cl-lib)
(require 'org)
(require 'org-recall-index)

(defmacro org-recall-index-test--with-clean-state (&rest body)
  `(let ((org-mode-hook org-mode-hook))
     (unwind-protect
         (progn
           (clrhash org-recall-index--inflight-update-processes)
           (clrhash org-recall-index--pending-update-requests)
           (when (get-buffer org-recall-index-diagnostics-buffer)
             (kill-buffer org-recall-index-diagnostics-buffer))
           ,@body)
       (clrhash org-recall-index--inflight-update-processes)
       (clrhash org-recall-index--pending-update-requests)
       (when (get-buffer org-recall-index-diagnostics-buffer)
         (kill-buffer org-recall-index-diagnostics-buffer))
       (org-recall-index-mode -1))))

(defmacro org-recall-index-test--with-dummy-process (binding &rest body)
  (declare (indent 1))
  (let ((process-var (car binding)))
    `(let* ((buffer (generate-new-buffer " *org-recall-index-test*"))
            (,process-var (start-process "org-recall-index-test" buffer "cat")))
       (set-process-query-on-exit-flag ,process-var nil)
       (unwind-protect
           (progn ,@body)
         (when (process-live-p ,process-var)
           (delete-process ,process-var))
         (when (buffer-live-p buffer)
           (kill-buffer buffer))))))

(ert-deftest org-recall-index-command-args-use-json-and-config ()
  (let ((org-recall-index-config-file "~/org-recall-index/config.txtpb"))
    (should (equal (org-recall-index--command-args "update-file" '("/tmp/file.org"))
                   (list "--json"
                         "--config"
                         (expand-file-name org-recall-index-config-file)
                         "update-file"
                         "/tmp/file.org")))))

(ert-deftest org-recall-index-command-args-omit-config-when-unset ()
  (let ((org-recall-index-config-file nil))
    (should (equal (org-recall-index--command-args "rebuild" nil)
                   '("--json" "rebuild")))))

(ert-deftest org-recall-index-update-buffer-starts-update-command ()
  (with-temp-buffer
    (org-mode)
    (setq-local buffer-file-name "/tmp/test.org")
    (cl-letf (((symbol-function 'org-recall-index--request-update)
               (lambda (path silent-success)
                 (should (equal path "/tmp/test.org"))
                 (should-not silent-success)
                 'process)))
      (should (eq (org-recall-index-update-buffer) 'process)))))

(ert-deftest org-recall-index-update-buffer-requires-file-backed-org-buffer ()
  (with-temp-buffer
    (org-mode)
    (should-error (org-recall-index-update-buffer) :type 'user-error))
  (with-temp-buffer
    (setq-local buffer-file-name "/tmp/test.txt")
    (should-error (org-recall-index-update-buffer) :type 'user-error)))

(ert-deftest org-recall-index-rebuild-starts-rebuild-command ()
  (cl-letf (((symbol-function 'org-recall-index--start-command)
             (lambda (subcommand arguments silent-success)
               (should (equal subcommand "rebuild"))
               (should-not arguments)
               (should-not silent-success)
               'process)))
    (should (eq (org-recall-index-rebuild) 'process))))

(ert-deftest org-recall-index-mode-installs-buffer-local-after-save-hooks ()
  (org-recall-index-test--with-clean-state
   (with-temp-buffer
     (org-mode)
     (org-recall-index-mode 1)
     (should (memq #'org-recall-index--enable-current-buffer org-mode-hook))
     (should (memq #'org-recall-index--after-save after-save-hook))
     (org-recall-index-mode -1)
     (should-not (memq #'org-recall-index--enable-current-buffer org-mode-hook))
     (should-not (memq #'org-recall-index--after-save after-save-hook)))))

(ert-deftest org-recall-index-mode-installs-hook-for-future-org-buffers ()
  (org-recall-index-test--with-clean-state
   (org-recall-index-mode 1)
   (with-temp-buffer
     (org-mode)
     (should (memq #'org-recall-index--after-save after-save-hook)))))

(ert-deftest org-recall-index-after-save-starts-update-for-org-file-buffers ()
  (with-temp-buffer
    (org-mode)
    (setq-local buffer-file-name "/tmp/test.org")
    (let ((org-recall-index-mode t)
          (org-recall-index-auto-sync t))
      (cl-letf (((symbol-function 'org-recall-index--request-update)
                 (lambda (path silent-success)
                   (should (equal path "/tmp/test.org"))
                   (should silent-success)
                   'started)))
        (should (eq (org-recall-index--after-save) 'started))))))

(ert-deftest org-recall-index-after-save-ignores-buffers-without-file-or-disabled-sync ()
  (with-temp-buffer
    (org-mode)
    (let ((org-recall-index-mode t)
          (org-recall-index-auto-sync t)
          (called nil))
      (cl-letf (((symbol-function 'org-recall-index--request-update)
                 (lambda (_path _silent-success)
                   (setq called t))))
        (org-recall-index--after-save)
        (should-not called))))
  (with-temp-buffer
    (org-mode)
    (setq-local buffer-file-name "/tmp/test.org")
    (let ((org-recall-index-mode t)
          (org-recall-index-auto-sync nil)
          (called nil))
      (cl-letf (((symbol-function 'org-recall-index--request-update)
                 (lambda (_path _silent-success)
                   (setq called t))))
        (org-recall-index--after-save)
        (should-not called)))))

(ert-deftest org-recall-index-request-update-starts-immediately-without-inflight-process ()
  (org-recall-index-test--with-clean-state
   (cl-letf (((symbol-function 'org-recall-index--start-update-process)
              (lambda (path silent-success)
                (should (equal path "/tmp/test.org"))
                (should silent-success)
                'process)))
     (should (eq (org-recall-index--request-update "/tmp/test.org" t) 'process)))))

(ert-deftest org-recall-index-request-update-queues-when-process-is-inflight ()
  (org-recall-index-test--with-clean-state
   (puthash "/tmp/test.org" 'running org-recall-index--inflight-update-processes)
   (cl-letf (((symbol-function 'org-recall-index--start-update-process)
              (lambda (_path _silent-success)
                (ert-fail "should not start a second concurrent update process"))))
     (should (eq (org-recall-index--request-update "/tmp/test.org" t) 'queued))
     (should (equal (gethash "/tmp/test.org" org-recall-index--pending-update-requests)
                    '(:silent-success t))))))

(ert-deftest org-recall-index-request-update-coalesces-queued-reruns-per-file-path ()
  (org-recall-index-test--with-clean-state
   (puthash "/tmp/test.org" 'running org-recall-index--inflight-update-processes)
   (org-recall-index--request-update "/tmp/test.org" t)
   (org-recall-index--request-update "/tmp/test.org" nil)
   (should (equal (gethash "/tmp/test.org" org-recall-index--pending-update-requests)
                  '(:silent-success nil)))))

(ert-deftest org-recall-index-drain-pending-update-starts-one-rerun-and-clears-queue ()
  (org-recall-index-test--with-clean-state
   (puthash "/tmp/test.org" '(:silent-success nil) org-recall-index--pending-update-requests)
   (cl-letf (((symbol-function 'org-recall-index--start-update-process)
              (lambda (path silent-success)
                (should (equal path "/tmp/test.org"))
                (should-not silent-success)
                'rerun-process)))
     (should (eq (org-recall-index--drain-pending-update "/tmp/test.org") 'rerun-process))
     (should-not (gethash "/tmp/test.org" org-recall-index--pending-update-requests)))))

(ert-deftest org-recall-index-handle-success-keeps-update-file-quiet-by-default ()
  (org-recall-index-test--with-clean-state
   (org-recall-index-test--with-dummy-process (process)
    (process-put process 'org-recall-index-subcommand "update-file")
    (process-put process 'org-recall-index-silent-success nil)
    (with-current-buffer (process-buffer process)
      (insert "{\"status\":\"updated\",\"path\":\"/tmp/test.org\",\"indexed_entry_count\":1}\n"))
    (let (messages)
      (cl-letf (((symbol-function 'message)
                 (lambda (format-string &rest args)
                   (push (apply #'format format-string args) messages))))
        (org-recall-index--handle-success process)
        (should-not messages))))))

(ert-deftest org-recall-index-handle-success-reports-manual-rebuilds ()
  (org-recall-index-test--with-clean-state
   (org-recall-index-test--with-dummy-process (process)
    (process-put process 'org-recall-index-subcommand "rebuild")
    (process-put process 'org-recall-index-silent-success nil)
    (with-current-buffer (process-buffer process)
      (insert "{\"indexed_file_count\":2,\"indexed_entry_count\":3}\n"))
    (let (messages)
      (cl-letf (((symbol-function 'message)
                 (lambda (format-string &rest args)
                   (push (apply #'format format-string args) messages))))
        (org-recall-index--handle-success process)
        (should (equal messages '("org-recall-index: rebuild finished (2 files, 3 entries)"))))))))

(ert-deftest org-recall-index-handle-failure-renders-grouped-duplicate-diagnostics ()
  (org-recall-index-test--with-clean-state
   (org-recall-index-test--with-dummy-process (process)
    (process-put process 'org-recall-index-subcommand "update-file")
    (process-put process 'org-recall-index-args '("--json" "update-file" "/tmp/test.org"))
    (with-current-buffer (process-buffer process)
      (insert "{\"error\":\"found 2 duplicate org IDs\",\"duplicates\":[{\"id\":\"another-id\",\"occurrences\":[{\"path\":\"/notes/one.org\",\"headline\":\"One\"},{\"path\":\"/notes/two.org\",\"headline\":\"Two\"}]},{\"id\":\"shared-id\",\"occurrences\":[{\"path\":\"/notes/three.org\",\"headline\":\"Three\"}]}]}\n"))
    (let (messages)
      (cl-letf (((symbol-function 'message)
                 (lambda (format-string &rest args)
                   (push (apply #'format format-string args) messages))))
        (org-recall-index--handle-failure process)
        (should (equal messages '("org-recall-index: duplicate Org IDs; see *org-recall-index*")))))
    (with-current-buffer (org-recall-index--diagnostics-buffer)
      (let ((text (buffer-string)))
        (should (string-match-p "update-file: duplicate Org IDs" text))
        (should (string-match-p "Command: org-recall-index --json update-file /tmp/test.org" text))
        (should (string-match-p "Summary: found 2 duplicate org IDs" text))
        (should (string-match-p "- another-id" text))
        (should (string-match-p "  - /notes/one.org: One" text))
        (should (string-match-p "  - /notes/two.org: Two" text))
        (should (string-match-p "- shared-id" text))
        (should (string-match-p "  - /notes/three.org: Three" text)))))))

(ert-deftest org-recall-index-start-command-records-start-errors-in-diagnostics-buffer ()
  (org-recall-index-test--with-clean-state
   (let ((org-recall-index-command "/definitely/missing/org-recall-index")
         messages)
     (cl-letf (((symbol-function 'message)
                (lambda (format-string &rest args)
                  (push (apply #'format format-string args) messages))))
       (should-not (org-recall-index--start-command "rebuild" nil nil))
       (should (equal messages '("org-recall-index: failed to start rebuild; see *org-recall-index*")))))
   (with-current-buffer (org-recall-index--diagnostics-buffer)
     (let ((text (buffer-string)))
       (should (string-match-p "rebuild: failed to start" text))
       (should (string-match-p "Command: /definitely/missing/org-recall-index --json rebuild" text))
       (should (string-match-p "Error:" text))))))

(ert-deftest org-recall-index-handle-success-records-malformed-json-diagnostics ()
  (org-recall-index-test--with-clean-state
   (org-recall-index-test--with-dummy-process (process)
    (process-put process 'org-recall-index-subcommand "update-file")
    (process-put process 'org-recall-index-args '("--json" "update-file" "/tmp/test.org"))
    (with-current-buffer (process-buffer process)
      (insert "not-json\n"))
    (let (messages)
      (cl-letf (((symbol-function 'message)
                 (lambda (format-string &rest args)
                   (push (apply #'format format-string args) messages))))
        (org-recall-index--handle-success process)
        (should (equal messages '("org-recall-index: malformed JSON from update-file; see *org-recall-index*")))))
    (with-current-buffer (org-recall-index--diagnostics-buffer)
      (let ((text (buffer-string)))
        (should (string-match-p "update-file: malformed JSON response" text))
        (should (string-match-p "Command: org-recall-index --json update-file /tmp/test.org" text))
        (should (string-match-p "Raw output:" text))
        (should (string-match-p "not-json" text)))))))

